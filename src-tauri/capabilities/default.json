{
  "identifier": "default",
  "description": "Default permissions for PC-Paralegal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$HOME/paralegal/**" },
        { "path": "$HOME/paralegal" }
      ]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$HOME/paralegal/**" }
      ]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [
        { "path": "$HOME/paralegal/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/paralegal/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/paralegal/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/paralegal/**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/paralegal/**" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "$HOME/paralegal/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/paralegal/**" }
      ]
    },
    "shell:default",
    "shell:allow-open",
    "core:app:allow-set-app-theme",
    "core:window:allow-set-theme",
    "core:window:allow-set-title"
  ]
}
